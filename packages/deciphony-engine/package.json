{
  "name": "deciphony-engine",
  "version": "0.0.1",
  "description": "Vue visual novel game rendering engine",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "**/*.css",
    "**/*.vue"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepublishOnly": "npm version patch"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "peerDependencies": {
    "element-plus": "^2.0.0",
    "vue": "^3.3.0",
    "vue-router": "^4.0.0"
  },
  "dependencies": {
    "deciphony-player": "^1.0.49",
    "gsap": "^3.13.0",
    "pinia": "^3.0.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "element-plus": "^2.11.8",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.21",
    "vue-router": "^4.6.3",
    "vue-tsc": "^3.0.5"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.14.0"
}
